# SlabPlan example environment variables.
#
# Copy to a local .env file only when needed. Never commit real values.

# Database
SUPABASE_DATABASE_URL=
SUPABASE_DIRECT_DATABASE_URL=
SUPABASE_SESSION_DATABASE_URL=

# Supabase storage
SUPABASE_URL=
SUPABASE_STORAGE_BUCKET=slabplan-files
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth/session secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_UPLOAD_SECRET=
JWT_RESET_SECRET=
SESSION_SECRET=

# App origins
APP_PUBLIC_URL=https://slabplan.vercel.app
CORS_ALLOWED_ORIGINS=https://slabplan.vercel.app
VITE_API_ORIGIN=https://slabplan-api-production.up.railway.app

# AI
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AGENT_MODEL=claude-sonnet-4-6

# Email
EMAIL_FROM=
EMAIL_REPLY_TO=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_PRO=

# Optional monitoring
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=

# Seed scripts only. Use strong one-off passphrases when intentionally
# creating local or staging users.
SEED_ADMIN_CESAR_PASSWORD=
SEED_ADMIN_ANWAR_PASSWORD=
