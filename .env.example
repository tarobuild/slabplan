# CAD Stone Networks — example environment variables.
#
# Copy to a local .env (NEVER commit) or set these via your shell / Replit
# Secrets before running scripts that need them.

# --- seed-users.mjs ---------------------------------------------------------
# Admin passwords used by `node artifacts/api-server/scripts/seed-users.mjs`.
# Each must be at least 12 characters and must NOT contain obvious patterns
# (see the script's WEAK_PASSWORD_PATTERNS list — e.g. "test", "password",
# "admin", "cadstone", or all-numeric values are rejected).
#
# These are ONLY used to insert the admin row when it does not already exist
# in the target database. They are not used to rotate an existing password —
# do that directly in the database / Supabase auth UI. See replit.md
# "Seed admin users" for the full runbook.
SEED_ADMIN_CESAR_PASSWORD=replace-with-a-strong-passphrase
SEED_ADMIN_ANWAR_PASSWORD=replace-with-a-strong-passphrase

# Local Postgres connection string used when running with --db=local.
DATABASE_URL=postgres://cadstone:cadstone@127.0.0.1:5432/cadstone

# Production (Supabase) connection string used when running with --db=production.
# Only set this when you intentionally need to point at the live database.
SUPABASE_DATABASE_URL=
