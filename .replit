modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "cloudrun"
build = "pnpm --filter @workspace/api-server run build"
run = "pnpm --filter @workspace/api-server run start"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-api-codegen"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-eager-bundle"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "knip"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flock -s /tmp/cadstone-api-codegen.lock pnpm run typecheck"

[[workflows.workflow]]
name = "check-api-codegen"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flock -x /tmp/cadstone-api-codegen.lock pnpm run check-api-codegen"

[[workflows.workflow]]
name = "check-eager-bundle"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/cadstone run check-eager-bundle"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "knip"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm knip"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.production]
CORS_ALLOWED_ORIGINS = "https://cadstonesystems.com"
NODE_ENV = "production"

[userenv.shared]
STORAGE_PROVIDER = "supabase"
SUPABASE_URL = "https://mfuoenqadqvavfjhzyba.supabase.co"
SUPABASE_STORAGE_BUCKET = "cadstone-files"

[objectStorage]
defaultBucketID = "replit-objstore-e7153229-d7cd-46a3-b318-10d50b6b412e"
