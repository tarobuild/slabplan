{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && node ./build.mjs && node --enable-source-maps ./dist/index.mjs",
    "build:server": "node ./build.mjs",
    "build": "pnpm --filter @workspace/cadstone run build && node ./build.mjs",
    "build:prod": "pnpm --filter @workspace/cadstone run build && node ./build.mjs",
    "start": "NODE_ENV=production node --enable-source-maps ./dist/index.mjs",
    "pretest": "node ./build.mjs && DATABASE_URL=\"${TEST_DATABASE_URL:-${CADSTONE_TEST_DATABASE_URL:-postgres://cadstone:cadstone@127.0.0.1:5432/cadstone_test}}\" pnpm --filter @workspace/db run ensure-test-db",
    "test": "AI_INTEGRATIONS_ANTHROPIC_BASE_URL=\"${AI_INTEGRATIONS_ANTHROPIC_BASE_URL:-http://stub.invalid}\" AI_INTEGRATIONS_ANTHROPIC_API_KEY=\"${AI_INTEGRATIONS_ANTHROPIC_API_KEY:-test-key}\" DATABASE_URL=\"${TEST_DATABASE_URL:-${CADSTONE_TEST_DATABASE_URL:-postgres://cadstone:cadstone@127.0.0.1:5432/cadstone_test}}\" tsx --test ./test/**/*.test.ts",
    "typecheck": "tsc --build ../../lib/db ../../lib/api-zod && tsc -p tsconfig.json --noEmit",
    "backfill-comment-attachments": "tsx ./src/scripts/backfill-comment-attachments.ts",
    "backup:db": "node ./scripts/db-backup.mjs",
    "backup:check": "node ./scripts/db-backup-check.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.51.0",
    "@tokenizer/inflate": "0.4.1",
    "@tokenizer/token": "0.3.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "@workspace/mcp-server": "workspace:*",
    "archiver": "7.0.1",
    "bcrypt": "6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5",
    "fflate": "0.8.2",
    "file-type": "22.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "9.0.2",
    "mammoth": "^1.12.0",
    "multer": "2.1.1",
    "peek-readable": "7.0.0",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^4.8.0",
    "socket.io": "^4.8.3",
    "strtok3": "10.3.5",
    "token-types": "6.1.2",
    "yaml": "^2.8.3",
    "zod": "3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/archiver": "6.0.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pg": "^8.20.0",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
