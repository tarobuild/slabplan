{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm --filter @workspace/cadstone run build && node ./build.mjs && node --enable-source-maps ./dist/index.mjs",
    "build": "pnpm --filter @workspace/cadstone run build && node ./build.mjs",
    "build:prod": "pnpm --filter @workspace/cadstone run build && node ./build.mjs",
    "start": "NODE_ENV=production node --enable-source-maps ./dist/index.mjs",
    "test": "tsx --test ./test/**/*.test.ts",
    "typecheck": "tsc --build ../../lib/db ../../lib/api-zod && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/mcp-server": "workspace:*",
    "archiver": "7.0.1",
    "bcrypt": "6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "2.1.1",
    "pino": "^9",
    "pino-http": "^10",
    "socket.io": "^4.8.3",
    "yaml": "^2.8.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "6.0.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
