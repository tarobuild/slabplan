{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./seed": "./src/seed.ts",
    "./migrate": "./src/migrate.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate --config ./drizzle.config.js",
    "db:migrate": "tsx ./src/migrate-cli.ts",
    "db:push": "drizzle-kit push --config ./drizzle.config.js",
    "generate": "drizzle-kit generate --config ./drizzle.config.js",
    "migrate": "tsx ./src/migrate-cli.ts",
    "push": "drizzle-kit push --config ./drizzle.config.js",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.js",
    "seed": "tsx ./src/seed-cli.ts",
    "build-files-folder-index": "tsx ./src/scripts/build-files-folder-index-concurrently.ts",
    "setup-test-db": "tsx ./src/scripts/setup-test-db.ts",
    "ensure-test-db": "tsx ./src/scripts/ensure-test-db.ts"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "4.21.0"
  }
}
